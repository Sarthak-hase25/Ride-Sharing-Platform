<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Poppins:wght@600;700;800&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }
        h1, h2, h3 {
            font-family: 'Poppins', sans-serif;
        }
    </style>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#0F172A',
                        secondary: '#06B6D4',
                        accent: '#F59E0B',
                        dark: '#1E293B',
                        light: '#F1F5F9'
                    }
                }
            }
        }
    </script>
</head>
<body class="min-h-screen flex flex-col bg-light">
    <%- include('../partials/navbar') %>
    
    <main class="flex-grow py-12 px-4">
        <div class="max-w-2xl mx-auto">
            <!-- Header -->
            <div class="text-center mb-8">
                <h1 class="text-4xl font-bold text-primary mb-2">Offer a Ride</h1>
                <p class="text-gray-600">Share your journey and help others save money!</p>
            </div>

            <!-- Form Card -->
            <div class="bg-white rounded-2xl shadow-2xl p-8">
                <!-- Error Message -->
                <% if (error) { %>
                    <div class="mb-6 bg-red-50 border-l-4 border-red-500 p-4 rounded">
                        <p class="text-red-700 text-sm"><%= error %></p>
                    </div>
                <% } %>

                <form action="/rides/create" method="POST">
                    <!-- Route Section -->
                    <div class="mb-8">
                        <h2 class="text-xs font-black text-secondary mb-6 flex items-center gap-2 uppercase tracking-[0.3em]">
                            <iconify-icon icon="solar:map-point-wave-bold-duotone" class="text-xl"></iconify-icon> Route Details
                        </h2>
                        
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <!-- From -->
                            <div>
                                <label class="block text-gray-500 text-[10px] font-black uppercase tracking-widest mb-2 flex items-center gap-2" for="from">
                                    <iconify-icon icon="solar:map-point-bold-duotone" class="text-secondary"></iconify-icon> Pickup Location
                                </label>
                                <input 
                                    class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-secondary focus:bg-white transition-all" 
                                    id="from" 
                                    name="from" 
                                    type="text"
                                    placeholder="Enter pickup point"
                                    required
                                >
                            </div>

                            <!-- To -->
                            <div>
                                <label class="block text-gray-500 text-[10px] font-black uppercase tracking-widest mb-2 flex items-center gap-2" for="to">
                                    <iconify-icon icon="solar:flag-bold-duotone" class="text-accent"></iconify-icon> Destination
                                </label>
                                <input 
                                    class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-secondary focus:bg-white transition-all" 
                                    id="to" 
                                    name="to" 
                                    type="text"
                                    placeholder="Enter destination"
                                    required
                                >
                            </div>
                        </div>
                    </div>

                    <!-- Date & Time Section -->
                    <div class="mb-8">
                        <h2 class="text-xs font-black text-secondary mb-6 flex items-center gap-2 uppercase tracking-[0.3em]">
                            <iconify-icon icon="solar:calendar-date-bold-duotone" class="text-xl"></iconify-icon> Schedule
                        </h2>
                        
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <!-- Date -->
                            <div>
                                <label class="block text-gray-500 text-[10px] font-black uppercase tracking-widest mb-2 flex items-center gap-2" for="date">
                                    <iconify-icon icon="solar:calendar-minimalistic-bold-duotone" class="text-secondary"></iconify-icon> Date
                                </label>
                                <input 
                                    class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-secondary focus:bg-white transition-all" 
                                    id="date" 
                                    name="date" 
                                    type="date"
                                    required
                                >
                            </div>

                            <!-- Time -->
                            <div>
                                <label class="block text-gray-500 text-[10px] font-black uppercase tracking-widest mb-2 flex items-center gap-2" for="time">
                                    <iconify-icon icon="solar:clock-circle-bold-duotone" class="text-secondary"></iconify-icon> Time
                                </label>
                                <input 
                                    class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-secondary focus:bg-white transition-all" 
                                    id="time" 
                                    name="time" 
                                    type="time"
                                    required
                                >
                            </div>
                        </div>
                    </div>

                    <!-- Vehicle & Pricing Section -->
                    <div class="mb-8">
                        <h2 class="text-xs font-black text-secondary mb-6 flex items-center gap-2 uppercase tracking-[0.3em]">
                            <iconify-icon icon="solar:bus-bold-duotone" class="text-xl"></iconify-icon> Vehicle & Pricing
                        </h2>
                        
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                            <!-- Vehicle Type -->
                            <div>
                                <label class="block text-gray-500 text-[10px] font-black uppercase tracking-widest mb-2 flex items-center gap-2" for="vehicleType">
                                    <iconify-icon icon="solar:car-bold-duotone" class="text-secondary"></iconify-icon> Vehicle Type
                                </label>
                                <select 
                                    class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-secondary focus:bg-white transition-all appearance-none" 
                                    id="vehicleType" 
                                    name="vehicleType"
                                    required
                                >
                                    <option value="">Select type</option>
                                    <option value="Car">Car</option>
                                    <option value="Bike">Bike</option>
                                    <option value="Auto">Auto</option>
                                    <option value="SUV">SUV</option>
                                </select>
                            </div>

                            <!-- Vehicle Number -->
                            <div>
                                <label class="block text-gray-500 text-[10px] font-black uppercase tracking-widest mb-2 flex items-center gap-2" for="vehicleNumber">
                                    <iconify-icon icon="solar:bill-list-bold-duotone" class="text-secondary"></iconify-icon> License Plate
                                </label>
                                <input 
                                    class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-secondary focus:bg-white transition-all uppercase" 
                                    id="vehicleNumber" 
                                    name="vehicleNumber" 
                                    type="text"
                                    placeholder="e.g. MH 12 AB 1234"
                                    required
                                >
                            </div>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <!-- Seats -->
                            <div>
                                <label class="block text-gray-500 text-[10px] font-black uppercase tracking-widest mb-2 flex items-center gap-2" for="seats">
                                    <iconify-icon icon="solar:users-group-rounded-bold-duotone" class="text-secondary"></iconify-icon> Available Seats
                                </label>
                                <input 
                                    class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-secondary focus:bg-white transition-all" 
                                    id="seats" 
                                    name="seats" 
                                    type="number"
                                    min="1"
                                    max="6"
                                    required
                                >
                            </div>

                            <!-- Price -->
                            <div>
                                <label class="block text-gray-500 text-[10px] font-black uppercase tracking-widest mb-2 flex items-center gap-2" for="price">
                                    <iconify-icon icon="solar:wallet-money-bold-duotone" class="text-secondary"></iconify-icon> Price per Seat (₹)
                                </label>
                                <input 
                                    class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-secondary focus:bg-white transition-all" 
                                    id="price" 
                                    name="price" 
                                    type="number"
                                    min="0"
                                    required
                                >
                            </div>
                        </div>
                    </div>

                    <!-- Additional Notes -->
                    <div class="mb-10">
                        <label class="block text-gray-500 text-[10px] font-black uppercase tracking-widest mb-2 flex items-center gap-2" for="notes">
                            <iconify-icon icon="solar:notes-bold-duotone" class="text-secondary"></iconify-icon> Additional Notes (Optional)
                        </label>
                        <textarea 
                            class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-secondary focus:bg-white transition-all" 
                            id="notes" 
                            name="notes"
                            rows="3"
                            placeholder="Add details about luggage, pickup specific points, etc."
                            maxlength="500"
                        ></textarea>
                    </div>

                    <!-- Submit Button -->
                    <div class="flex flex-col sm:flex-row gap-4">
                        <button 
                            type="submit"
                            class="flex-1 bg-secondary text-white font-bold py-4 px-8 rounded-xl hover:bg-cyan-500 transition-all hover:scale-[1.02] active:scale-[0.98] shadow-lg shadow-secondary/25 flex items-center justify-center gap-2"
                        >
                            <iconify-icon icon="solar:check-circle-bold-duotone" class="text-xl"></iconify-icon>
                            Post Ride
                        </button>
                        <a 
                            href="/dashboard"
                            class="flex-1 bg-gray-100 text-gray-600 font-bold py-4 px-8 rounded-xl hover:bg-gray-200 transition-all text-center flex items-center justify-center gap-2"
                        >
                            <iconify-icon icon="solar:close-circle-bold-duotone" class="text-xl"></iconify-icon>
                            Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </main>
    
    <%- include('../partials/footer') %>

    <script>
        // Set minimum date to today
        document.getElementById('date').min = new Date().toISOString().split('T')[0];
    </script>
</body>
</html>