<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Poppins:wght@600;700;800&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }
        h1, h2, h3 {
            font-family: 'Poppins', sans-serif;
        }
    </style>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#0F172A',
                        secondary: '#06B6D4',
                        accent: '#F59E0B',
                        dark: '#1E293B',
                        light: '#F1F5F9'
                    }
                }
            }
        }
    </script>
</head>
<body class="min-h-screen flex flex-col bg-light">
    <%- include('../partials/navbar') %>
    
    <main class="flex-grow py-12">
        <div class="container mx-auto px-4">
            <!-- Header -->
            <div class="flex flex-col md:flex-row justify-between items-center mb-10 gap-6">
                <div>
                    <h1 class="text-4xl font-black text-primary mb-2 uppercase tracking-tighter">My Shared Trips</h1>
                    <p class="text-gray-500 font-medium">Manage and track the rides you've offered to the community</p>
                </div>
                <a href="/rides/create" class="bg-secondary text-white px-8 py-4 rounded-2xl font-black hover:bg-cyan-500 transition-all shadow-xl shadow-secondary/20 flex items-center gap-2 hover:scale-[1.02] active:scale-95">
                    <iconify-icon icon="solar:add-circle-bold-duotone" class="text-2xl"></iconify-icon>
                    OFFER NEW RIDE
                </a>
            </div>

            <!-- Rides List -->
            <% if (rides && rides.length > 0) { %>
                <div class="space-y-8">
                    <% rides.forEach(ride => { %>
                        <div class="bg-white rounded-3xl shadow-xl overflow-hidden border border-gray-100 hover:shadow-2xl transition-all group">
                            <div class="flex flex-col lg:flex-row">
                                <!-- Status Sidebar -->
                                <% 
                                    const now = new Date();
                                    const rideDate = new Date(ride.date);
                                    const today = new Date(now.getFullYear(), now.getMonth(), now.getDate());
                                    const rideDateOnly = new Date(rideDate.getFullYear(), rideDate.getMonth(), rideDate.getDate());
                                    const currentTime = now.getHours().toString().padStart(2, '0') + ':' + now.getMinutes().toString().padStart(2, '0');
                                    const isExpired = rideDateOnly < today || (rideDateOnly.getTime() === today.getTime() && ride.time < currentTime);
                                    
                                    let statusColor = 'bg-secondary';
                                    let statusText = 'Active';
                                    let statusIcon = 'solar:check-circle-bold-duotone';

                                    if (ride.status === 'cancelled') {
                                        statusColor = 'bg-red-500';
                                        statusText = 'Cancelled';
                                        statusIcon = 'solar:close-circle-bold-duotone';
                                    } else if (isExpired) {
                                        statusColor = 'bg-gray-400';
                                        statusText = 'Completed';
                                        statusIcon = 'solar:history-bold-duotone';
                                    }
                                %>
                                <div class="<%= statusColor %> text-white px-6 py-4 lg:w-16 flex lg:flex-col items-center justify-center gap-2">
                                    <iconify-icon icon="<%= statusIcon %>" class="text-2xl lg:text-3xl"></iconify-icon>
                                    <span class="font-black text-[10px] uppercase tracking-widest lg:[writing-mode:vertical-lr] lg:rotate-180"><%= statusText %></span>
                                </div>

                                <!-- Content -->
                                <div class="flex-1 p-8">
                                    <div class="flex flex-col md:flex-row justify-between gap-8">
                                        <!-- Route & Details -->
                                        <div class="flex-1">
                                            <div class="flex flex-wrap items-center gap-4 mb-6">
                                                <div class="flex items-center gap-3">
                                                    <div class="w-2.5 h-2.5 bg-secondary rounded-full shadow-sm shadow-secondary/50"></div>
                                                    <span class="font-black text-xl text-primary"><%= ride.from %></span>
                                                </div>
                                                <iconify-icon icon="solar:alt-arrow-right-bold-duotone" class="text-gray-300 text-2xl"></iconify-icon>
                                                <div class="flex items-center gap-3">
                                                    <div class="w-2.5 h-2.5 bg-accent rounded-full shadow-sm shadow-accent/50"></div>
                                                    <span class="font-black text-xl text-primary"><%= ride.to %></span>
                                                </div>
                                            </div>

                                            <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
                                                <div class="flex items-center gap-3">
                                                    <div class="w-10 h-10 bg-gray-50 rounded-xl flex items-center justify-center text-secondary">
                                                        <iconify-icon icon="solar:calendar-date-bold-duotone" class="text-xl"></iconify-icon>
                                                    </div>
                                                    <div>
                                                        <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest">Date</p>
                                                        <p class="font-black text-sm text-gray-700">
                                                            <%= new Date(ride.date).toLocaleDateString('en-IN', { day: 'numeric', month: 'short' }) %>
                                                        </p>
                                                    </div>
                                                </div>
                                                <div class="flex items-center gap-3">
                                                    <div class="w-10 h-10 bg-gray-50 rounded-xl flex items-center justify-center text-accent">
                                                        <iconify-icon icon="solar:clock-circle-bold-duotone" class="text-xl"></iconify-icon>
                                                    </div>
                                                    <div>
                                                        <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest">Time</p>
                                                        <p class="font-black text-sm text-gray-700"><%= ride.time %></p>
                                                    </div>
                                                </div>
                                                <div class="flex items-center gap-3">
                                                    <div class="w-10 h-10 bg-gray-50 rounded-xl flex items-center justify-center text-secondary">
                                                        <iconify-icon icon="solar:users-group-rounded-bold-duotone" class="text-xl"></iconify-icon>
                                                    </div>
                                                    <div>
                                                        <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest">Booked</p>
                                                        <p class="font-black text-sm text-gray-700"><%= ride.passengers.length %> / <%= ride.seats %></p>
                                                    </div>
                                                </div>
                                                <div class="flex items-center gap-3">
                                                    <div class="w-10 h-10 bg-gray-50 rounded-xl flex items-center justify-center text-green-500">
                                                        <iconify-icon icon="solar:wallet-money-bold-duotone" class="text-xl"></iconify-icon>
                                                    </div>
                                                    <div>
                                                        <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest">Earnings</p>
                                                        <p class="font-black text-sm text-gray-700">₹<%= ride.price * ride.passengers.length %></p>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Actions -->
                                        <div class="flex md:flex-col justify-end gap-3 min-w-[160px]">
                                            <a href="/rides/<%= ride._id %>" class="flex-1 bg-primary text-white px-6 py-3 rounded-xl font-black text-sm hover:bg-secondary transition-all flex items-center justify-center gap-2 group-hover:shadow-lg shadow-primary/20">
                                                <iconify-icon icon="solar:eye-bold-duotone"></iconify-icon>
                                                DETAILS
                                            </a>
                                            <% if (ride.status === 'active' && !isExpired) { %>
                                                <form action="/rides/<%= ride._id %>/cancel" method="POST" onsubmit="return confirm('Cancel this ride? Passengers will be notified.');" class="flex-1">
                                                    <button type="submit" class="w-full bg-red-50 text-red-500 px-6 py-3 rounded-xl font-black text-sm hover:bg-red-500 hover:text-white transition-all flex items-center justify-center gap-2">
                                                        <iconify-icon icon="solar:trash-bin-trash-bold-duotone"></iconify-icon>
                                                        CANCEL
                                                    </button>
                                                </form>
                                            <% } %>
                                        </div>
                                    </div>

                                    <!-- Passengers Preview -->
                                    <% if (ride.passengers.length > 0) { %>
                                        <div class="mt-8 pt-6 border-t border-gray-50">
                                            <p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest mb-4">Confirmed Passengers</p>
                                            <div class="flex flex-wrap gap-3">
                                                <% ride.passengers.forEach(passenger => { %>
                                                    <div class="flex items-center gap-3 bg-light/50 px-4 py-2 rounded-2xl border border-gray-100">
                                                        <div class="w-8 h-8 bg-secondary/10 text-secondary rounded-full flex items-center justify-center font-black text-xs">
                                                            <%= passenger.name.charAt(0).toUpperCase() %>
                                                        </div>
                                                        <div>
                                                            <p class="font-black text-xs text-gray-700"><%= passenger.name %></p>
                                                            <p class="text-[10px] text-gray-400 font-bold">📱 <%= passenger.phone %></p>
                                                        </div>
                                                    </div>
                                                <% }) %>
                                            </div>
                                        </div>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } else { %>
                <!-- Empty State -->
                <div class="bg-white rounded-3xl p-16 text-center shadow-xl border border-gray-100">
                    <div class="w-32 h-32 bg-gray-50 rounded-3xl flex items-center justify-center mx-auto mb-8 text-7xl text-gray-200 rotate-3">
                        <iconify-icon icon="solar:steering-wheel-bold-duotone"></iconify-icon>
                    </div>
                    <h3 class="text-3xl font-black text-primary mb-4">Ready to Earn?</h3>
                    <p class="text-gray-500 text-lg mb-10 max-w-md mx-auto">
                        You haven't offered any rides yet. Share your journey today and start saving on your travel costs while helping others.
                    </p>
                    <a href="/rides/create" class="inline-block px-10 py-5 bg-secondary text-white rounded-2xl font-black hover:bg-cyan-500 transition-all shadow-2xl shadow-secondary/20 hover:scale-105 active:scale-95">
                        OFFER YOUR FIRST RIDE
                    </a>
                </div>
            <% } %>
        </div>
    </main>
    
    <%- include('../partials/footer') %>
</body>
</html>