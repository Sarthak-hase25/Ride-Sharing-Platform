<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Poppins:wght@600;700;800&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }
        h1, h2, h3 {
            font-family: 'Poppins', sans-serif;
        }
    </style>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#0F172A',
                        secondary: '#06B6D4',
                        accent: '#F59E0B',
                        dark: '#1E293B',
                        light: '#F1F5F9'
                    }
                }
            }
        }
    </script>
</head>
<body class="min-h-screen flex flex-col bg-light">
    <%- include('../partials/navbar') %>
    
    <main class="flex-grow flex items-center justify-center py-12 px-4">
        <div class="max-w-md w-full">
            <!-- Card -->
            <div class="bg-white rounded-2xl shadow-2xl p-8">
                <!-- Header -->
                <div class="text-center mb-8">
                    <div class="inline-flex items-center justify-center w-16 h-16 bg-gradient-to-br from-secondary to-cyan-400 rounded-2xl mb-4 shadow-lg shadow-secondary/20">
                        <iconify-icon icon="solar:login-bold-duotone" class="text-3xl text-white"></iconify-icon>
                    </div>
                    <h1 class="text-3xl font-bold text-primary mb-2">Welcome Back</h1>
                    <p class="text-gray-600">Login to continue your journey!</p>
                </div>

                <!-- Error Message -->
                <% if (error) { %>
                    <div class="mb-8 bg-red-50 border border-red-100 p-4 rounded-2xl flex items-center gap-3 animate-in fade-in slide-in-from-top-4">
                        <iconify-icon icon="solar:danger-bold-duotone" class="text-xl text-red-500"></iconify-icon>
                        <p class="text-red-700 font-bold"><%= error %></p>
                    </div>
                <% } %>

                <!-- Form -->
                <form action="/login" method="POST">
                    <!-- Email -->
                    <div class="mb-4">
                        <label class="block text-gray-500 text-[10px] font-black uppercase tracking-widest mb-2 flex items-center gap-2" for="email">
                            <iconify-icon icon="solar:letter-bold-duotone" class="text-secondary"></iconify-icon> Email Address
                        </label>
                        <input 
                            class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-secondary focus:bg-white transition-all" 
                            id="email" 
                            name="email" 
                            type="email"
                            placeholder="your@email.com"
                            required
                        >
                    </div>

                    <!-- Password -->
                    <div class="mb-6">
                        <label class="block text-gray-500 text-[10px] font-black uppercase tracking-widest mb-2 flex items-center gap-2" for="password">
                            <iconify-icon icon="solar:lock-password-bold-duotone" class="text-secondary"></iconify-icon> Password
                        </label>
                        <input 
                            class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-secondary focus:bg-white transition-all" 
                            id="password" 
                            name="password" 
                            type="password"
                            placeholder="••••••••"
                            required
                        >
                    </div>

                    <!-- Submit Button -->
                    <button 
                        class="w-full bg-secondary text-white font-bold py-4 px-6 rounded-xl hover:bg-cyan-500 transition-all hover:scale-[1.02] active:scale-[0.98] shadow-lg shadow-secondary/25 flex items-center justify-center gap-2"
                        type="submit"
                    >
                        <iconify-icon icon="solar:login-bold-duotone" class="text-xl"></iconify-icon>
                        Login
                    </button>
                </form>

                <!-- Footer -->
                <div class="mt-6 text-center">
                    <p class="text-gray-600 text-sm">
                        Don't have an account? 
                        <a href="/signup" class="text-secondary hover:text-cyan-500 font-semibold">Sign up here</a>
                    </p>
                </div>
            </div>
        </div>
    </main>
    
    <%- include('../partials/footer') %>
</body>
</html>