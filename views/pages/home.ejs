<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Poppins:wght@600;700;800&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }
        h1, h2, h3 {
            font-family: 'Poppins', sans-serif;
        }
    </style>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#0F172A',      // Dark Navy
                        secondary: '#06B6D4',    // Cyan
                        accent: '#F59E0B',       // Amber
                        dark: '#1E293B',         // Slate Dark
                        light: '#F1F5F9'         // Slate Light
                    }
                }
            }
        }
    </script>
</head>
<body class="min-h-screen flex flex-col bg-light">
    <%- include('../partials/navbar') %>
    
    <main class="flex-grow">
        <!-- Hero Section -->
        <section class="bg-gradient-to-br from-primary via-dark to-slate-800 text-white py-16 md:py-32 relative overflow-hidden">
            <!-- Decorative elements -->
            <div class="absolute top-0 right-0 w-96 h-96 bg-secondary opacity-10 rounded-full blur-3xl"></div>
            <div class="absolute bottom-0 left-0 w-96 h-96 bg-accent opacity-10 rounded-full blur-3xl"></div>
            
            <div class="container mx-auto px-4 text-center relative z-10">
                <div class="inline-block mb-4 px-4 py-2 bg-secondary bg-opacity-20 rounded-full text-secondary text-sm font-semibold">
                    🚗 Shared Journeys, Better Connections
                </div>
                <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold mb-6 leading-tight">
                    Your Smart
                    <span class="text-transparent bg-clip-text bg-gradient-to-r from-secondary to-accent">
                        Ride Share
                    </span>
                    <br>Community
                </h1>
                <p class="text-lg sm:text-xl md:text-2xl mb-10 text-gray-300 max-w-3xl mx-auto">
                    Connect with people heading your way. Save money, reduce carbon footprint, and make new connections on every journey.
                </p>
                <div class="flex flex-col sm:flex-row gap-4 justify-center px-4">
                    <a href="/rides" class="group px-8 py-4 bg-secondary text-white rounded-xl font-semibold hover:bg-cyan-500 transition-all hover:scale-105 shadow-xl shadow-secondary/50 flex items-center justify-center gap-3">
                        <iconify-icon icon="solar:magnifer-bold-duotone" class="text-2xl"></iconify-icon>
                        <span>Find a Ride</span>
                        <iconify-icon icon="solar:alt-arrow-right-bold-duotone" class="group-hover:translate-x-1 transition-transform"></iconify-icon>
                    </a>
                    <a href="/signup" class="group px-8 py-4 bg-white text-primary rounded-xl font-semibold hover:bg-gray-100 transition-all hover:scale-105 shadow-xl flex items-center justify-center gap-3">
                        <iconify-icon icon="solar:user-plus-bold-duotone" class="text-2xl text-secondary"></iconify-icon>
                        <span>Join Now</span>
                    </a>
                </div>
                
                <!-- Stats -->
                <div class="grid grid-cols-3 gap-4 md:gap-8 mt-16 max-w-2xl mx-auto">
                    <div class="text-center group">
                        <div id="stat-users" class="text-3xl md:text-4xl font-bold text-secondary group-hover:scale-110 transition-transform"><%= stats.totalUsers %></div>
                        <div class="text-sm md:text-base text-gray-400 mt-1 flex items-center justify-center gap-1">
                            <iconify-icon icon="solar:users-group-rounded-bold-duotone"></iconify-icon> Active Members
                        </div>
                    </div>
                    <div class="text-center group">
                        <div id="stat-rides" class="text-3xl md:text-4xl font-bold text-accent group-hover:scale-110 transition-transform"><%= stats.totalRides %></div>
                        <div class="text-sm md:text-base text-gray-400 mt-1 flex items-center justify-center gap-1">
                            <iconify-icon icon="solar:map-arrow-square-bold-duotone"></iconify-icon> Trips Shared
                        </div>
                    </div>
                    <div class="text-center group">
                        <div id="stat-money" class="text-3xl md:text-4xl font-bold text-secondary group-hover:scale-110 transition-transform">₹<%= stats.totalMoneySaved %></div>
                        <div class="text-sm md:text-base text-gray-400 mt-1 flex items-center justify-center gap-1">
                            <iconify-icon icon="solar:wallet-money-bold-duotone"></iconify-icon> Total Savings
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Features Section -->
        <section class="py-16 md:py-24">
            <div class="container mx-auto px-4">
                <div class="text-center mb-12 md:mb-16">
                    <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-primary mb-4">
                        Why People Choose WayMate
                    </h2>
                    <p class="text-gray-600 text-lg max-w-2xl mx-auto">
                        Join thousands of commuters who are already saving money and making their daily travel more enjoyable
                    </p>
                </div>
                
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
                    <!-- Feature 1 -->
                    <div class="group bg-white p-8 rounded-2xl shadow-lg hover:shadow-2xl transition-all border-2 border-transparent hover:border-secondary">
                        <div class="w-20 h-20 bg-cyan-50 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 group-hover:rotate-3 transition-transform text-4xl text-secondary">
                            <iconify-icon icon="solar:banknote-2-bold-duotone"></iconify-icon>
                        </div>
                        <h3 class="text-2xl font-bold mb-3 text-primary">Save Big Money</h3>
                        <p class="text-gray-600 leading-relaxed">Split fuel costs and save up to 70% on your daily commute. More money for what matters!</p>
                    </div>
                    
                    <!-- Feature 2 -->
                    <div class="group bg-white p-8 rounded-2xl shadow-lg hover:shadow-2xl transition-all border-2 border-transparent hover:border-accent">
                        <div class="w-20 h-20 bg-amber-50 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 group-hover:rotate-3 transition-transform text-4xl text-accent">
                            <iconify-icon icon="solar:leaf-bold-duotone"></iconify-icon>
                        </div>
                        <h3 class="text-2xl font-bold mb-3 text-primary">Eco-Friendly</h3>
                        <p class="text-gray-600 leading-relaxed">Reduce carbon emissions by sharing rides. One car, multiple passengers, massive impact!</p>
                    </div>
                    
                    <!-- Feature 3 -->
                    <div class="group bg-white p-8 rounded-2xl shadow-lg hover:shadow-2xl transition-all border-2 border-transparent hover:border-secondary">
                        <div class="w-20 h-20 bg-cyan-50 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 group-hover:rotate-3 transition-transform text-4xl text-secondary">
                            <iconify-icon icon="solar:users-group-two-rounded-bold-duotone"></iconify-icon>
                        </div>
                        <h3 class="text-2xl font-bold mb-3 text-primary">Social Commute</h3>
                        <p class="text-gray-600 leading-relaxed">Meet people, share stories, and turn your travel into a rewarding social experience.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- CTA Section -->
        <section class="py-16 bg-gradient-to-r from-primary to-dark text-white">
            <div class="container mx-auto px-4 text-center">
                <h2 class="text-3xl md:text-4xl font-bold mb-4">Ready to Start Saving?</h2>
                <p class="text-xl text-gray-300 mb-8">Join our community today!</p>
                <a href="/signup" class="inline-block px-8 py-4 bg-secondary text-white rounded-xl font-semibold hover:bg-cyan-500 transition-all hover:scale-105 shadow-xl">
                    Sign Up Now - It's Free! 🎉
                </a>
            </div>
        </section>
    </main>
    
    <%- include('../partials/footer') %>

    <!-- Live Stats Update Script -->
    <script>
        async function updateStats() {
            try {
                const response = await fetch('/api/stats');
                const data = await response.json();
                
                if (data) {
                    const usersEl = document.getElementById('stat-users');
                    const ridesEl = document.getElementById('stat-rides');
                    const moneyEl = document.getElementById('stat-money');
                    
                    if (usersEl) usersEl.textContent = data.totalUsers;
                    if (ridesEl) ridesEl.textContent = data.totalRides;
                    if (moneyEl) moneyEl.textContent = '₹' + data.totalMoneySaved;
                }
            } catch (err) {
                console.error('Failed to update stats:', err);
            }
        }

        // Update every 5 seconds
        setInterval(updateStats, 5000);
    </script>
</body>
</html>