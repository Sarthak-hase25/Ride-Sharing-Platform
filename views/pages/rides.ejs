<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Poppins:wght@600;700;800&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }
        h1, h2, h3 {
            font-family: 'Poppins', sans-serif;
        }
    </style>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#0F172A',
                        secondary: '#06B6D4',
                        accent: '#F59E0B',
                        dark: '#1E293B',
                        light: '#F1F5F9'
                    }
                }
            }
        }
    </script>
</head>
<body class="min-h-screen flex flex-col bg-light">
    <%- include('../partials/navbar') %>
    
    <main class="flex-grow py-12">
        <div class="container mx-auto px-4">
            <!-- Header -->
            <div class="text-center mb-12">
                <h1 class="text-5xl md:text-6xl font-black text-primary mb-4 uppercase tracking-tighter">Available Rides</h1>
                <p class="text-gray-500 text-lg font-medium">Explore active journeys and connect with travelers in your network</p>
            </div>

            <!-- Search & Filter Form -->
            <div class="bg-white rounded-2xl shadow-xl p-8 mb-10 border border-gray-100">
                <form action="/rides" method="GET">
                    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
                        <!-- From -->
                        <div class="relative">
                            <label class="block text-gray-500 text-[10px] font-black uppercase tracking-widest mb-2 flex items-center gap-2" for="from">
                                <iconify-icon icon="solar:map-point-wave-bold-duotone" class="text-secondary"></iconify-icon> From
                            </label>
                            <input 
                                class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-secondary focus:bg-white transition-all" 
                                id="from" 
                                name="from" 
                                type="text"
                                value="<%= filters && filters.from ? filters.from : '' %>"
                                placeholder="Enter location"
                            >
                        </div>

                        <!-- To -->
                        <div class="relative">
                            <label class="block text-gray-500 text-[10px] font-black uppercase tracking-widest mb-2 flex items-center gap-2" for="to">
                                <iconify-icon icon="solar:flag-bold-duotone" class="text-accent"></iconify-icon> To
                            </label>
                            <input 
                                class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-secondary focus:bg-white transition-all" 
                                id="to" 
                                name="to" 
                                type="text"
                                value="<%= filters && filters.to ? filters.to : '' %>"
                                placeholder="Enter destination"
                            >
                        </div>

                        <!-- Date -->
                        <div class="relative">
                            <label class="block text-gray-500 text-[10px] font-black uppercase tracking-widest mb-2 flex items-center gap-2" for="date">
                                <iconify-icon icon="solar:calendar-date-bold-duotone" class="text-secondary"></iconify-icon> Date
                            </label>
                            <input 
                                class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-secondary focus:bg-white transition-all" 
                                id="date" 
                                name="date" 
                                type="date"
                                value="<%= filters && filters.date ? filters.date : '' %>"
                            >
                        </div>

                        <!-- Buttons -->
                        <div class="flex gap-3 items-end">
                            <button 
                                type="submit"
                                class="flex-1 bg-primary text-white font-black py-4 px-6 rounded-2xl hover:bg-secondary transition-all shadow-xl shadow-primary/20 flex items-center justify-center gap-2 uppercase tracking-widest text-xs"
                            >
                                <iconify-icon icon="solar:magnifer-bold-duotone" class="text-lg"></iconify-icon> Search
                            </button>
                            <a 
                                href="/rides"
                                class="bg-gray-100 text-gray-500 font-black py-4 px-4 rounded-2xl hover:bg-gray-200 transition-all flex items-center justify-center uppercase tracking-widest text-xs group"
                                title="Reset"
                            >
                                <iconify-icon icon="solar:refresh-bold-duotone" class="text-xl group-hover:rotate-180 transition-all duration-500"></iconify-icon>
                            </a>
                        </div>
                    </div>
                </form>
            </div>

            <!-- Results Count -->
            <% if (filters && (filters.from || filters.to || filters.date)) { %>
                <div class="mb-8 flex items-center gap-2 text-gray-600">
                    <iconify-icon icon="solar:tuning-bold-duotone" class="text-xl text-secondary"></iconify-icon>
                    <p>
                        Found <span class="font-bold text-secondary text-lg"><%= rides.length %></span> matching ride(s)
                    </p>
                </div>
            <% } %>

            <!-- Rides List -->
            <% if (rides && rides.length > 0) { %>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                    <% rides.forEach(ride => { %>
                        <div class="group bg-white rounded-2xl shadow-lg hover:shadow-2xl transition-all border border-gray-100 hover:border-secondary p-8 flex flex-col h-full overflow-hidden relative">
                            <!-- Premium Badge -->
                            <div class="absolute top-0 right-0 bg-secondary/10 text-secondary px-4 py-1 rounded-bl-xl font-bold text-xs uppercase tracking-wider flex items-center gap-1">
                                <iconify-icon icon="solar:star-bold-duotone"></iconify-icon> Active
                            </div>

                            <!-- Route -->
                            <div class="mb-6 relative">
                                <!-- Vertical Connector Line -->
                                <div class="absolute left-1.5 top-5 bottom-5 w-0.5 bg-gray-100 dashed border-l-2 border-dashed border-gray-300"></div>
                                
                                <div class="flex items-start gap-4 mb-5 relative z-10">
                                    <div class="w-3.5 h-3.5 bg-secondary rounded-full mt-1.5 shadow-md shadow-secondary/30 ring-4 ring-secondary/10"></div>
                                    <div class="flex-1">
                                        <p class="text-xs text-gray-400 uppercase font-bold tracking-widest mb-0.5">Pickup</p>
                                        <p class="font-bold text-gray-800 text-lg"><%= ride.from %></p>
                                    </div>
                                </div>
                                <div class="flex items-start gap-4 relative z-10">
                                    <div class="w-3.5 h-3.5 bg-accent rounded-full mt-1.5 shadow-md shadow-accent/30 ring-4 ring-accent/10"></div>
                                    <div class="flex-1">
                                        <p class="text-xs text-gray-400 uppercase font-bold tracking-widest mb-0.5">Destination</p>
                                        <p class="font-bold text-gray-800 text-lg"><%= ride.to %></p>
                                    </div>
                                </div>
                            </div>

                            <!-- Date & Time Chips -->
                            <div class="grid grid-cols-3 gap-3 mb-6">
                                <div class="bg-gray-50 p-2.5 rounded-xl border border-gray-100 text-center">
                                    <iconify-icon icon="solar:calendar-date-bold-duotone" class="text-secondary text-xl mb-1"></iconify-icon>
                                    <p class="text-[10px] text-gray-400 uppercase font-bold">Date</p>
                                    <p class="font-bold text-gray-800 text-xs">
                                        <%= new Date(ride.date).toLocaleDateString('en-IN', { day: 'numeric', month: 'short' }) %>
                                    </p>
                                </div>
                                <div class="bg-gray-50 p-2.5 rounded-xl border border-gray-100 text-center">
                                    <iconify-icon icon="solar:clock-circle-bold-duotone" class="text-accent text-xl mb-1"></iconify-icon>
                                    <p class="text-[10px] text-gray-400 uppercase font-bold">Time</p>
                                    <p class="font-bold text-gray-800 text-xs"><%= ride.time %></p>
                                </div>
                                <div class="bg-gray-50 p-2.5 rounded-xl border border-gray-100 text-center">
                                    <iconify-icon icon="solar:bus-bold-duotone" class="text-secondary text-xl mb-1"></iconify-icon>
                                    <p class="text-[10px] text-gray-400 uppercase font-bold">Type</p>
                                    <p class="font-bold text-gray-800 text-xs"><%= ride.vehicleType %></p>
                                </div>
                            </div>

                            <!-- Driver Info -->
                            <div class="flex items-center gap-3 mb-6 p-3 bg-light/50 rounded-xl">
                                <div class="w-10 h-10 bg-secondary rounded-full flex items-center justify-center text-white font-bold text-lg shadow-inner">
                                    <%= ride.driver.name.charAt(0).toUpperCase() %>
                                </div>
                                <div class="flex-1 min-w-0">
                                    <p class="text-xs text-gray-400 font-bold uppercase tracking-tighter">Hosted by</p>
                                    <p class="font-bold text-gray-800 truncate"><%= ride.driver.name %></p>
                                </div>
                                <div class="text-right">
                                    <div class="flex items-center gap-1 text-accent">
                                        <iconify-icon icon="solar:star-bold"></iconify-icon>
                                        <span class="font-bold text-sm">4.8</span>
                                    </div>
                                </div>
                            </div>

                            <!-- Spacer -->
                            <div class="flex-grow"></div>

                            <!-- Footer: Price & Seats -->
                            <div class="flex items-center justify-between pt-6 border-t border-gray-100">
                                <div>
                                    <p class="text-gray-400 text-[10px] font-bold uppercase mb-0.5">Price / Seat</p>
                                    <div class="flex items-baseline gap-1">
                                        <span class="text-3xl font-black text-secondary">₹<%= ride.price %></span>
                                    </div>
                                </div>
                                <div class="text-right">
                                    <p class="text-gray-400 text-[10px] font-bold uppercase mb-0.5">Availability</p>
                                    <div class="flex items-center justify-end gap-1.5 font-black text-gray-800">
                                        <iconify-icon icon="solar:users-group-rounded-bold-duotone" class="text-xl text-secondary"></iconify-icon>
                                        <span class="text-xl"><%= ride.seats - ride.passengers.length %>/<%= ride.seats %></span>
                                    </div>
                                </div>
                            </div>

                            <!-- Action -->
                            <a href="/rides/<%= ride._id %>" class="mt-6 block w-full bg-primary text-white text-center font-bold py-4 rounded-xl hover:bg-secondary transition-all shadow-lg hover:shadow-secondary/30 active:scale-95 flex items-center justify-center gap-2">
                                <span>Book This Ride</span>
                                <iconify-icon icon="solar:alt-arrow-right-bold-duotone"></iconify-icon>
                            </a>
                        </div>
                    <% }) %>
                </div>
            <% } else { %>
                <!-- No Rides Found -->
                <div class="bg-white rounded-3xl p-16 text-center shadow-xl border border-gray-100">
                    <div class="w-32 h-32 bg-gray-50 rounded-full flex items-center justify-center mx-auto mb-8 text-7xl text-gray-200">
                        <iconify-icon icon="solar:map-point-remove-bold-duotone"></iconify-icon>
                    </div>
                    <h3 class="text-3xl font-black text-primary mb-4">
                        <% if (filters && (filters.from || filters.to || filters.date)) { %>
                            No Rides Match Your Search
                        <% } else { %>
                            No Rides Available Right Now
                        <% } %>
                    </h3>
                    <p class="text-gray-500 text-lg mb-10 max-w-md mx-auto">
                        <% if (filters && (filters.from || filters.to || filters.date)) { %>
                            Try adjusting your search criteria or clear filters to see all available journeys.
                        <% } else { %>
                            Be the pioneer! Offer a ride today and help others while saving your fuel costs.
                        <% } %>
                    </p>
                    <div class="flex flex-col sm:flex-row gap-4 justify-center">
                        <% if (filters && (filters.from || filters.to || filters.date)) { %>
                            <a href="/rides" class="px-8 py-4 bg-gray-100 text-gray-600 rounded-xl font-bold hover:bg-gray-200 transition-all flex items-center justify-center gap-2">
                                <iconify-icon icon="solar:refresh-bold-duotone"></iconify-icon> Clear All Filters
                            </a>
                        <% } %>
                        <a href="/rides/create" class="px-8 py-4 bg-secondary text-white rounded-xl font-bold hover:bg-cyan-500 transition-all shadow-xl shadow-secondary/20 flex items-center justify-center gap-2">
                            <iconify-icon icon="solar:steering-wheel-bold-duotone"></iconify-icon> Offer a New Ride
                        </a>
                    </div>
                </div>
            <% } %>
        </div>
    </main>
    
    <%- include('../partials/footer') %>

    <script>
        // Set minimum date to today
        document.getElementById('date').min = new Date().toISOString().split('T')[0];
    </script>
</body>
</html>